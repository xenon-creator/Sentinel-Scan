# ==========================================
# 🛑 Backend Configuration
# ==========================================

# Database Configuration
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=sentinel_scan

# Message Broker / Cache
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Application Settings
DEBUG=true
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Security
SECRET_KEY=replace-this-with-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
SCAN_TIMEOUT_SECONDS=3600
MAX_CONCURRENT_SCANS=5

# Directories
REPORTS_DIR=./reports
SCAN_RESULTS_DIR=./scan_results

# ==========================================
# 🌐 External API Integrations (Backend)
# ==========================================
NVD_API_KEY=your_nvd_api_key_here
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
SHODAN_API_KEY=your_shodan_api_key_here
ALIENVAULT_API_KEY=your_alienvault_api_key_here

# ==========================================
# 🖥️ Frontend Configuration (Vite)
# ==========================================
# In Vite, variables must start with VITE_ to be exposed to the client
VITE_API_URL=http://localhost:8000
VITE_VIRUSTOTAL_ENABLED=true
VITE_ABUSEIPDB_ENABLED=true
VITE_SHODAN_ENABLED=false
VITE_ALIENVAULT_ENABLED=true
