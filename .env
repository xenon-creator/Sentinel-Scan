# ==========================================
# 🛑 Backend Configuration
# ==========================================

# Database Configuration
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=sentinel_scan

# Message Broker / Cache
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Application Settings
DEBUG=true
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Security
SECRET_KEY=replace-this-with-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
SCAN_TIMEOUT_SECONDS=3600
MAX_CONCURRENT_SCANS=5

# Directories
REPORTS_DIR=./reports
SCAN_RESULTS_DIR=./scan_results

# ==========================================
# 🌐 External API Integrations (Backend)
# ==========================================
NVD_API_KEY=REDACTED_NVD_KEY
VIRUSTOTAL_API_KEY=REDACTED_VT_KEY
ABUSEIPDB_API_KEY=REDACTED_ABUSEIPDB_KEY
OSV_API_BASE_URL=https://api.osv.dev/v1

# ==========================================
# 🖥️ Frontend Configuration (Vite)
# ==========================================
# In Vite, variables must start with VITE_ to be exposed to the client
VITE_API_URL=http://localhost:8000
VITE_VIRUSTOTAL_ENABLED=true
VITE_ABUSEIPDB_ENABLED=true
VITE_NVD_ENABLED=true
VITE_OSV_ENABLED=true
