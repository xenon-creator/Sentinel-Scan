# ==========================================
# Sentinel-Scan Environment Configuration
# ==========================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in EVERY value marked <REPLACE_ME>
# 3. NEVER commit .env — it is in .gitignore
# ==========================================

# Database Configuration
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=sentinel_scan

# Message Broker / Cache
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Application Settings
DEBUG=true
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Security — generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<REPLACE_ME>
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
SCAN_TIMEOUT_SECONDS=3600
MAX_CONCURRENT_SCANS=5

# Directories
REPORTS_DIR=./reports
SCAN_RESULTS_DIR=./scan_results

# ==========================================
# External API Integrations
# ==========================================
# NVD (NIST) — https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=<REPLACE_ME>

# VirusTotal — https://www.virustotal.com/gui/user/apikey
VIRUSTOTAL_API_KEY=<REPLACE_ME>

# AbuseIPDB — https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=<REPLACE_ME>

# OSV (no key required)
OSV_API_BASE_URL=https://api.osv.dev/v1

# ==========================================
# Frontend Configuration (Vite)
# ==========================================
VITE_API_URL=http://localhost:8000
VITE_VIRUSTOTAL_ENABLED=true
VITE_ABUSEIPDB_ENABLED=true
VITE_NVD_ENABLED=true
VITE_OSV_ENABLED=true

# ==========================================
# OWASP ZAP Configuration
# ==========================================
# ZAP proxy host and port (default: 127.0.0.1:8080)
ZAP_PROXY_HOST=127.0.0.1
ZAP_PROXY_PORT=8080

# ZAP API key — leave empty if ZAP is started with -config api.disablekey=true
ZAP_API_KEY=

# Scan timeouts (seconds)
ZAP_SPIDER_TIMEOUT=300
ZAP_ACTIVE_SCAN_TIMEOUT=1800

# ZAP log file path
ZAP_LOG_FILE=./logs/zap.log
